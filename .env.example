# =============================================================================
# ARA Caregiver Assistant - Environment Configuration Example
# Copy this file to .env and modify values as needed
# =============================================================================

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3001
LOG_LEVEL=info

# =============================================================================
# Ollama Configuration (Optional - for AI-enhanced extraction)
# =============================================================================

# Ollama server URL
# Windows/Linux/Mac with local Ollama:
OLLAMA_URL=http://localhost:11434
# Docker setup (if using docker-compose):
# OLLAMA_URL=http://ollama:11434

# Model to use for AI extraction
# Options (from smallest/fastest to largest/best quality):
#   - qwen2.5:0.5b          (0.5B params, ~300MB, fastest, lowest quality)
#   - qwen3:4b-q4_K_M       (4B params, ~2.3GB, RECOMMENDED, good balance)
#   - qwen3:4b-q8_0         (4B params, ~3.5GB, higher quality)
#   - qwen3:4b-fp16         (4B params, ~7.5GB, best quality)
#   - llama3.2:3b           (3B params, ~2GB, alternative)
#   - llama3:8b             (8B params, ~4.7GB, higher quality)
OLLAMA_MODEL=qwen3:4b-q4_K_M

# Set to "true" to disable LLM entirely (OCR-only mode)
# This works without Ollama and processes entirely locally
DISABLE_LLM=false

# Context length in tokens (default: 8192)
# Increase for very long transcripts, decrease for faster processing
OLLAMA_CONTEXT_LENGTH=8192

# Request timeout in milliseconds (default: 90000 = 90 seconds)
# Increase if you have slower hardware or experience timeouts
OLLAMA_TIMEOUT=90000

# =============================================================================
# OCR Configuration
# =============================================================================

# Minimum confidence threshold for OCR text (0-100)
# Lower values accept more text but may have errors
# Higher values reject uncertain text
OCR_CONFIDENCE_THRESHOLD=50

# Maximum file size in bytes (default: 52428800 = 50MB)
MAX_FILE_SIZE=52428800

# =============================================================================
# Security & Privacy
# =============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# Platform-Specific Notes
# =============================================================================

# Windows Users:
# - Install Ollama from: https://ollama.com/download/windows
# - Ollama runs as a service on http://localhost:11434
# - PowerShell env vars: $env:OLLAMA_MODEL="qwen3:4b-q4_K_M"
# - CMD env vars: set OLLAMA_MODEL=qwen3:4b-q4_K_M

# macOS Users:
# - Install Ollama: brew install ollama  OR  https://ollama.com/download/mac
# - Ollama runs on http://localhost:11434
# - Set env vars: export OLLAMA_MODEL=qwen3:4b-q4_K_M

# Linux Users:
# - Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
# - Ollama runs on http://localhost:11434
# - Set env vars: export OLLAMA_MODEL=qwen3:4b-q4_K_M

# Docker Users:
# - Ollama container runs on http://ollama:11434 (internal network)
# - See docker-compose.yml for Docker-specific configuration

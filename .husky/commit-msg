#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Commit message validation for conventional commits
commit_msg_file="$1"
commit_msg=$(head -n1 "$commit_msg_file")

# Pattern: type(scope): message or type: message
pattern="^(feat|fix|docs|style|refactor|test|chore|ci|build)(\([a-z-]+\))?: .+"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
    echo "❌ Invalid commit message format."
    echo ""
    echo "Expected format: <type>(<scope>): <message>"
    echo ""
    echo "Types:"
    echo "  feat:     A new feature"
    echo "  fix:      A bug fix"
    echo "  docs:     Documentation changes"
    echo "  style:    Code style changes (formatting, etc)"
    echo "  refactor: Code refactoring"
    echo "  test:     Test changes"
    echo "  chore:    Maintenance tasks"
    echo "  ci:       CI/CD changes"
    echo "  build:    Build system changes"
    echo ""
    echo "Examples:"
    echo "  feat: add batch processing endpoint"
    echo "  fix(ocr): handle corrupted PDF files"
    echo "  docs: update API documentation"
    exit 1
fi

echo "✅ Commit message format is valid"

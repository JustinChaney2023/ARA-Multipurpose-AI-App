# ARA Local AI Service Configuration
# Copy this file to .env and modify as needed

# Server Configuration
PORT=3001
LOG_LEVEL=info

# Ollama Configuration
OLLAMA_URL=http://localhost:11434

# Model Configuration
# Default: qwen3:4b-q4_K_M (Qwen3-4B with 4-bit quantization)
# Options:
#   - qwen3:4b-q4_K_M  (Recommended, ~2.3GB, good quality)
#   - qwen3:4b-q8_0    (Higher quality, ~3.5GB)
#   - qwen3:4b-fp16    (Best quality, ~7.5GB)
#   - qwen2.5:0.5b     (Fastest, lowest quality)
#   - llama3:8b        (Alternative model)
OLLAMA_MODEL=qwen3:4b-q4_K_M

# Disable LLM entirely (use rule-based extraction only)
# DISABLE_LLM=false

# Context Length (tokens)
# Default 8192 is good for most forms
# Increase for very long transcripts
# OLLAMA_CONTEXT_LENGTH=8192

# Request Timeouts (milliseconds)
# Increase if you have slower hardware
# OLLAMA_TIMEOUT=90000

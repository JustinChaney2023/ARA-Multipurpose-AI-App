# ARA Local AI Service Configuration
# Copy this file to .env and modify as needed

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3001
LOG_LEVEL=info

# ============================================================================
# Ollama Configuration
# ============================================================================
OLLAMA_URL=http://localhost:11434

# Model Configuration
# Default: qwen3:4b-q4_K_M (Qwen3-4B with 4-bit quantization)
# 
# CPU-ONLY USERS (No NVIDIA GPU):
#   Use smaller models for better performance:
#   - qwen2.5:1.5b     (Recommended for CPU, ~1GB, decent quality)
#   - qwen2.5:0.5b     (Fastest on CPU, ~400MB, lower quality)
#   - phi3:mini        (Good CPU option, ~2.2GB)
#
# GPU Users (NVIDIA):
#   - qwen3:4b-q4_K_M  (Recommended, ~2.3GB, good quality)
#   - qwen3:4b-q8_0    (Higher quality, ~3.5GB)
#   - qwen3:4b-fp16    (Best quality, ~7.5GB)
#   - llama3:8b        (Alternative model)
#
# NOTE: On Windows, Ollama only supports NVIDIA GPUs. Intel/AMD GPUs will use CPU.
OLLAMA_MODEL=qwen3:4b-q4_K_M

# Disable LLM entirely (use rule-based extraction only)
# DISABLE_LLM=false

# ============================================================================
# Performance & GPU Optimization
# ============================================================================

# GPU Acceleration
# OLLAMA_GPU_ENABLED=true           # Enable GPU acceleration (default: true)
# OLLAMA_NUM_GPU_LAYERS=-1          # GPU layers to offload (-1 = auto, 0 = CPU only)
# OLLAMA_MAIN_GPU=0                 # Primary GPU device ID
# OLLAMA_TENSOR_SPLIT=              # Multi-GPU split (e.g., "3,1" for 75%/25%)

# Performance Tuning
# OLLAMA_NUM_THREAD=0               # CPU threads (0 = auto)
# OLLAMA_NUM_BATCH=512              # Batch size for prompt processing
# OLLAMA_NUM_PREDICT=1500           # Max tokens to generate
# OLLAMA_NUM_CTX=8192               # Context window size

# Generation Parameters
# OLLAMA_TEMPERATURE=0.1            # Sampling temperature (0.0 - 1.0)
# OLLAMA_TOP_P=0.9                  # Nucleus sampling
# OLLAMA_TOP_K=40                   # Top-k sampling
# OLLAMA_REPEAT_PENALTY=1.0         # Repetition penalty
# OLLAMA_FREQUENCY_PENALTY=0.0      # Frequency penalty
# OLLAMA_PRESENCE_PENALTY=0.0       # Presence penalty

# ============================================================================
# Connection Pooling
# ============================================================================

# HTTP Connection Pooling
# OLLAMA_POOL_ENABLED=true          # Enable connection pooling (default: true)
# OLLAMA_POOL_MAX_SOCKETS=10        # Max concurrent connections
# OLLAMA_POOL_KEEP_ALIVE=true       # Keep connections alive
# OLLAMA_POOL_KEEP_ALIVE_MS=30000   # Keep-alive timeout

# ============================================================================
# Timeouts & Retries
# ============================================================================

# Request Timeouts (milliseconds — defaults: 60s text, 120s vision)
# Increase if you have slower hardware or experience timeouts
# OLLAMA_TIMEOUT=60000
# OLLAMA_VISION_TIMEOUT=120000

# Retry Configuration
# OLLAMA_MAX_RETRIES=2              # Max retry attempts for failed requests

# ============================================================================
# OCR Configuration
# ============================================================================

# OCR_CONFIDENCE_THRESHOLD=50       # Minimum confidence for high confidence (0-100)
# MAX_FILE_SIZE=52428800            # Max upload size in bytes (50MB)
# PDF_DENSITY=300                   # PDF to image DPI

# Embedding model for RAG vector search (default: nomic-embed-text)
# Must be pulled in Ollama:  ollama pull nomic-embed-text
# EMBED_MODEL=nomic-embed-text

# Host to bind the service to (default: localhost)
# HOST=localhost

# Custom tesseract language data path (optional)
# TESSERACT_LANG_PATH=./tessdata

# Progress tracking TTL and cleanup (milliseconds)
# PROGRESS_TTL=300000
# PROGRESS_CLEANUP_INTERVAL=60000

# SQLite database path (default: data/ara.db)
# DB_PATH=data/ara.db

# ============================================================================
# Upload & Storage
# ============================================================================

# UPLOAD_MAX_FILES=10               # Max files per upload
# UPLOAD_CLEANUP_INTERVAL=300000    # Temp file cleanup interval (5 min)
# UPLOAD_TEMP_DIR=uploads           # Temporary upload directory

# ============================================================================
# Model Warmup
# ============================================================================

# DISABLE_WARMUP=false              # Disable model warmup
# WARMUP_KEEP_ALIVE=60000           # Keep-alive ping interval (1 min)
# WARMUP_INITIAL_DELAY=1000         # Initial warmup delay (1 sec)

# ============================================================================
# Feature Toggles
# ============================================================================

# DISABLE_WARMUP=false              # Disable model warmup

# ============================================================================
# Phase 3/4 — Persistence & RAG
# ============================================================================

# Embedding model for RAG vector search (default: nomic-embed-text)
# Must be pulled in Ollama:  ollama pull nomic-embed-text
# EMBED_MODEL=nomic-embed-text

# Host to bind the service to (default: localhost)
# HOST=localhost

# Custom tesseract language data path (optional)
# TESSERACT_LANG_PATH=./tessdata

# Progress tracking TTL and cleanup (milliseconds)
# PROGRESS_TTL=300000
# PROGRESS_CLEANUP_INTERVAL=60000

# SQLite database path (default: data/ara.db)
# DB_PATH=data/ara.db
